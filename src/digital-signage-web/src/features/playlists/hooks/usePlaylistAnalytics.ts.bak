import { useQuery, useQueries, UseQueryResult } from '@tanstack/react-query';
import { analyticsService } from '@/services/analyticsService';
import type { 
  PlaylistAnalyticsData,
  PlaylistViewMetrics,
  DeviceMetrics,
  MediaItemAnalytics
} from '@/features/playlists/components/PlaylistAnalytics';

/**
 * Query key factory for playlist analytics
 * Provides consistent query keys and helps with cache management
 */
export const playlistAnalyticsKeys = {
  all: ['playlist-analytics'] as const,
  playlist: (playlistId: number) => [...playlistAnalyticsKeys.all, playlistId] as const,
  analytics: (playlistId: number, dateRange?: { from: Date; to: Date }) => 
    [...playlistAnalyticsKeys.playlist(playlistId), 'analytics', dateRange] as const,
  trends: (playlistId: number, days?: number) => 
    [...playlistAnalyticsKeys.playlist(playlistId), 'trends', days] as const,
  devices: (playlistId: number) => 
    [...playlistAnalyticsKeys.playlist(playlistId), 'devices'] as const,
  media: (playlistId: number) => 
    [...playlistAnalyticsKeys.playlist(playlistId), 'media'] as const,
  summary: (playlistId: number) => 
    [...playlistAnalyticsKeys.playlist(playlistId), 'summary'] as const,
} as const;

/**
 * Configuration options for playlist analytics queries
 */
export interface PlaylistAnalyticsOptions {
  /** Enable/disable the query */
  enabled?: boolean;
  /** Refetch interval in milliseconds */
  refetchInterval?: number;
  /** Stale time in milliseconds */
  staleTime?: number;
  /** Cache time in milliseconds */
  cacheTime?: number;
}

/**
 * Hook for getting comprehensive playlist analytics data
 * @param playlistId - ID of the playlist
 * @param dateRange - Optional date range filter
 * @param options - Query configuration options
 */
export function usePlaylistAnalyticsData(
  playlistId: number,
  dateRange?: { from: Date; to: Date },
  options: PlaylistAnalyticsOptions = {}
): UseQueryResult<PlaylistAnalyticsData, Error> {
  const {
    enabled = !!playlistId,
    refetchInterval,
    staleTime = 5 * 60 * 1000, // 5 minutes
    cacheTime = 10 * 60 * 1000, // 10 minutes
  } = options;

  return useQuery({
    queryKey: playlistAnalyticsKeys.analytics(playlistId, dateRange) as readonly unknown[],
    queryFn: () => analyticsService.getPlaylistAnalytics(playlistId, dateRange),
    enabled,
    refetchInterval,
    staleTime,
    gcTime: cacheTime,
    refetchOnWindowFocus: false,
    retry: (failureCount, error) => {
      // Don't retry on 404 or 403 errors
      if (error && 'status' in error && (error.status === 404 || error.status === 403)) {
        return false;
      }
      return failureCount < 3;
    },
  });
}

/**
 * Hook for getting playlist view trends over time
 * @param playlistId - ID of the playlist
 * @param days - Number of days to look back
 * @param options - Query configuration options
 */
export function usePlaylistViewTrends(
  playlistId: number,
  days: number = 30,
  options: PlaylistAnalyticsOptions = {}
): UseQueryResult<PlaylistViewMetrics[], Error> {
  const {
    enabled = !!playlistId,
    refetchInterval,
    staleTime = 5 * 60 * 1000,
    cacheTime = 10 * 60 * 1000,
  } = options;

  return useQuery({
    queryKey: playlistAnalyticsKeys.trends(playlistId, days),
    queryFn: () => analyticsService.getPlaylistViewTrends(playlistId, days),
    enabled,
    refetchInterval,
    staleTime,
    cacheTime,
    refetchOnWindowFocus: false,
  });
}

/**
 * Hook for getting device performance metrics for a playlist
 * @param playlistId - ID of the playlist
 * @param options - Query configuration options
 */
export function usePlaylistDeviceMetrics(
  playlistId: number,
  options: PlaylistAnalyticsOptions = {}
): UseQueryResult<DeviceMetrics[], Error> {
  const {
    enabled = !!playlistId,
    refetchInterval = 2 * 60 * 1000, // 2 minutes for device status
    staleTime = 1 * 60 * 1000, // 1 minute for device data
    cacheTime = 5 * 60 * 1000,
  } = options;

  return useQuery({
    queryKey: playlistAnalyticsKeys.devices(playlistId),
    queryFn: () => analyticsService.getPlaylistDeviceMetrics(playlistId),
    enabled,
    refetchInterval,
    staleTime,
    cacheTime,
    refetchOnWindowFocus: false,
  });
}

